<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_ai_enrichment_wizard_form" model="ir.ui.view">
            <field name="name">ai.enrichment.wizard.form</field>
            <field name="model">ai.enrichment.wizard</field>
            <field name="arch" type="xml">
                <form string="AI Enrichment">
                    <group>
                        <field name="product_ids" widget="many2many_tags"/>
                        
                        <!-- This is your first dropdown -->
                        <field name="provider"/>
                        
                        <!-- This is your second dropdown, which is now filtered by the first -->
                        <field name="config_id" options="{'no_create': True, 'no_open': True}"/>
                        
                        <field name="update_field"/>
                        <field name="prompt_type_config" wiget="many2many_tags"/>
                        <label for="product_count"/>
                        <div>
                            <field name="product_count" readonly="1"/>
                        </div>
                        <!-- <field name="loading_html" readonly="1" nolabel="1"/> -->
                    </group>
                    <footer>
                        <button string="Enrich ✨" type="object" name="action_enrich" class="btn-primary"/>
                        <button string="Cancel" class="btn-secondary" special="cancel"/>
                    </footer>
                </form>
            </field>
    </record>

    <record id="action_ai_enrichment_wizard" model="ir.actions.act_window">
        <field name="name">AI Enrichment</field>
        <field name="res_model">ai.enrichment.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <record id="server_action_ai_enrichment" model="ir.actions.server">
        <field name="name">AI Enrichment ✨</field>
        <field name="model_id" ref="product.model_product_template"/>
        <field name="binding_model_id" ref="product.model_product_template"/>
        <field name="state">code</field>
        <field name="code">action = records.action_push_to_channel()</field>
    </record>
</odoo>