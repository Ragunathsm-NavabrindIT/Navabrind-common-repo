<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_product_template_form_inherit_retail_price" model="ir.ui.view">
        <field name="name">product.template.form.inherit.retail.price</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_form_view"/>
        <field name="arch" type="xml">

            <!-- Add Retail Price (invisible field for internal use) -->
            <xpath expr="//field[@name='list_price']" position="after">
                <field name="retail_price" invisible="1" readonly="1"/>
            </xpath>

            <!-- Add Secondary Quantity Total Field-->
              <xpath expr="//field[@name='uom_po_id']" position="after">
                <field name="secondary_quantity_total" readonly="1"/>
            </xpath>
        </field>
    </record>
</odoo>
