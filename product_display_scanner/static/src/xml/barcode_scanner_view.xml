<?xml version="1.0" encoding="UTF-8" ?>
<templates xml:space="preserve">

    <t t-name="product_display_scanner.ScannerView" owl="1">
        <div class="d-flex flex-column vh-100 p-4" style="background: linear-gradient(to bottom, #f0f2f5, #ffffff);">
            <!-- Top Centered Search Box -->
            <div class="text-center mb-5 mt-3 position-relative search-bar-wrapper">
                <div class="search-bar-container mx-auto shadow-sm">
                    <i class="fa fa-search search-icon"></i>
                    <input
                        type="text"
                        class="form-control search-input"
                        placeholder="Scan or Enter Product Barcode..."
                        t-ref="barcodeInput"
                        t-on-input="_onScan"
                        autocomplete="off"
                    />
                    <span class="scan-indicator"></span>
                </div>
            </div>

            <div class="result-container flex-grow-1 w-100 d-flex align-items-center justify-content-center">
                <!-- ✅ Product Card Section -->
                <t t-if="state.product">
                    <div class="card product-display-clean border-0"
                        style="width: 100%; max-width: 1450px; min-height: 650px; margin-bottom:20px; border-radius: 1.5rem; background: #ffffff; box-shadow: 0 20px 60px rgba(0,0,0,0.08); overflow: hidden; animation: fadeInCard 1.2s ease-out;">
                        <div class="row g-0 align-items-center">
                            <!-- Product Image Section -->
                            <div class="col-md-6 d-flex align-items-center justify-content-center p-5" 
                                style="background: linear-gradient(to bottom right, #f9f9f9, #f3f3f3); border-right: 1px solid #eee;">
                                <div class="p-3 rounded-4 bg-white shadow-sm" style="border: 1px solid #e0e0e0;">
                                    <img t-att-src="state.product.image_url" alt="Product Image"
                                        class="img-fluid rounded-3"
                                        style="max-height: 500px; object-fit: contain; animation: floatImage 5s ease-in-out infinite;"/>
                                </div>
                            </div>
                            <!-- Product Details Section -->
                            <div class="col-md-6 p-5 d-flex flex-column justify-content-center bg-white">   
                                <!-- Product Name -->
                                <h1 class="fw-bold text-dark mb-3" style="font-size: 2.6rem;">
                                    <t t-esc="state.product.display_name"/>
                                </h1>
                                <!-- Product Info -->
                                <div class="row mb-4">
                                    <div class="col-6">
                                        <h6 class="text-muted fw-bold text-uppercase small mb-1">Product Code</h6>
                                        <p class="h5 fw-light mb-0 text-dark" t-esc="state.product.default_code || 'N/A'"/>
                                    </div>
                                    <div class="col-6">
                                        <h6 class="text-muted fw-bold text-uppercase small mb-1">Barcode</h6>
                                        <p class="h5 fw-light mb-0 text-dark" t-esc="state.product.barcode || 'N/A'"/>
                                    </div>
                                </div>
                                <hr class="my-4" style="border-top: 1px dashed #dcdcdc;"/>
                                <!-- Quantity -->
                                <div class="mb-4">
                                    <h6 class="text-muted fw-bold text-uppercase small mb-1">Quantity On Hand</h6>
                                    <p t-attf-class="display-3 fw-bolder mb-0 {{ state.product.secondary_quantity_total > 0 ? 'text-success' : 'text-danger' }}">
                                        <t t-esc="state.product.secondary_quantity_total"/>
<!--                                        <span class="h5 fw-semibold align-baseline ms-2 text-muted">-->
<!--                                            <t t-esc="state.product.uom_name"/>-->
<!--                                        </span>-->
                                                <span class="h5 fw-semibold align-baseline ms-2 text-muted">Pieces</span>
                                    </p>
                                </div>
                                <!-- Price Section -->
                                <div class="p-4 mt-3 rounded-3 shadow-sm"
                                    style="border: 1px solid #e4d7e1; background: #faf8fb;">
                                    <h6 class="text-muted fw-bold text-uppercase small mb-2">Price (INR)</h6>
                                    <p class="display-3 fw-bolder mb-1" style="color: #8a4d76;">
                                        <t t-if="state.product.retail_price_value and state.product.retail_price_value > 0">
                                            <t t-esc="state.product.price_formatted"/>
                                        </t>
                                        <t t-else="">
                                            ₹<t t-esc="(state.product.list_price || 0).toFixed(2)"/>
                                        </t>
                                        <t t-if="state.product.uom_name">
<!--                                            <span class="fs-4 fw-semibold align-baseline ms-2" style="color: #5a2a50;">-->
<!--                                                per <t t-esc="state.product.uom_name"/>-->
<!--                                            </span>-->
                                                 <span class="h5 fw-semibold align-baseline ms-2 text-muted">per Pieces</span>
                                        </t>
                                    </p>
                                    <div style="height: 3px; width: 90px; background: linear-gradient(90deg, #8a4d76, #dca3c2); border-radius: 2px;"></div>
                                </div>
                            </div>
                        </div>
                    </div>
                </t>

                <!-- ❌ Product Not Found Section -->
                <t t-if="state.notFound">
                    <div class="text-center">
                        <div class="alert alert-danger p-5 shadow-sm border-0" role="alert">
                            <h2 class="alert-heading">Product Not Found</h2>
                            <p class="mb-0 text-muted">Please scan a valid barcode.</p>
                        </div>
                    </div>
                </t>

                <!-- 🌀 Carousel / Ready to Scan Section -->
                <t t-if="!state.product and !state.notFound">
                    <div class="w-100 h-100 d-flex flex-column align-items-center justify-content-center">
                        <t t-if="state.advertisements.length > 1">
                            <div class="carousel-3d-container">
                                <div class="carousel-3d" t-ref="carousel3d">
                                    <t t-foreach="state.advertisements" t-as="ad" t-key="ad.id">
                                        <div class="carousel-3d-item" t-on-click="() => this._onSlideClick(ad_index)">
                                            <img t-att-src="ad.image_url" alt="Advertisement Image"/>
                                            <div class="caption">
                                                <span t-esc="`${ad.display_name}`"/>
                                            </div>
                                        </div>
                                    </t>
                                </div>
                            </div>
                        </t>
                        <t t-elif="state.advertisements.length === 1">
                            <div class="d-flex flex-column align-items-center" style="height: 80%; position: relative;">
                                <div class="card shadow-lg border-0 h-100" style="width: 500px; border-radius: 1.25rem; overflow: hidden; background-color: white;">
                                    <img t-att-src="state.advertisements[0].image_url" class="w-100 h-100" alt="Advertisement Image" style="object-fit: contain; padding: 1rem;"/>
                                    <div class="caption active">
                                        <span t-esc="`${state.advertisements[0].display_name}`"/>
                                    </div>
                                </div>
                            </div>
                        </t>
                        <t t-else="">
                            <div class="text-center text-muted d-flex flex-column align-items-center justify-content-center h-100">
                                <svg xmlns="http://www.w3.org/2000/svg" width="80" height="80" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="0.5" stroke-linecap="round" stroke-linejoin="round" class="text-black-50 mb-3">
                                    <path d="M3 5v14"/>
                                    <path d="M8 5v14"/>
                                    <path d="M12 5v14"/>
                                    <path d="M17 5v14"/>
                                    <path d="M21 5v14"/>
                                </svg>
                                <h4 class="fw-light">Ready to Scan</h4>
                            </div>
                        </t>
                    </div>
                </t>
            </div>
        </div>
    </t>
</templates>
