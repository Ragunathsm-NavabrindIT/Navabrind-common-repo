<?xml version="1.0" encoding="utf-8"?>

<odoo>

    <!-- ================================================= -->
    <!-- TREE VIEW -->
    <!-- ================================================= -->

    <record id="view_smart_search_result_tree"
            model="ir.ui.view">

        <field name="name">smart.search.result.tree</field>

        <field name="model">smart.search.result</field>

        <field name="arch"
               type="xml">

            <list>

                <field name="product_name"/>

                <field name="searched_value"/>

                <field name="source_website"/>

                <field name="image_count"/>

                <field name="create_date"/>

            </list>

        </field>

    </record>

    <!-- ================================================= -->
    <!-- FORM VIEW -->
    <!-- ================================================= -->

    <record id="view_smart_search_result_form"
            model="ir.ui.view">

        <field name="name">smart.search.result.form</field>

        <field name="model">smart.search.result</field>

        <field name="arch"
               type="xml">

            <form string="Search Result">

                <sheet>

                    <group>

                        <group>

                            <field name="name"/>

                            <field name="product_name"/>

                            <field name="searched_value"/>

                            <field name="source_website"/>

                        </group>

                        <group>

                            <field name="product_url"
                                   widget="url"/>

                            <field name="product_id"/>

                            <field name="image_count"/>

                        </group>

                    </group>

                    <!-- ===================================== -->
                                     <!-- IMAGES -->
                    <!-- ===================================== -->

                    <notebook>

                        <page string="Images">

                            <field name="image_ids">

                                <list editable="bottom">

                                    <field name="image"/>

                                    <field name="name"/>

                                    <field name="image_url"/>

                                </list>

                            </field>

                        </page>

                        <!-- ================================= -->
                        <!-- ATTRIBUTES -->
                        <!-- ================================= -->

                        <page string="Attributes">

                            <field name="attribute_ids">

                                <list editable="bottom">

                                    <field name="name"/>

                                    <field name="value"/>

                                </list>

                            </field>

                        </page>

                    </notebook>

                </sheet>

            </form>

        </field>

    </record>

</odoo>
