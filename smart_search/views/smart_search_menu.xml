<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- RESULTS ACTION -->

    <record id="action_smart_search_results"
            model="ir.actions.act_window">

        <field name="name">Search Results</field>
        <field name="res_model">smart.search.result</field>
        <field name="view_mode">list,form</field>

    </record>

    <!-- ROOT MENU -->

    <menuitem
        id="menu_smart_search_root"
        name="Smart Search"
        sequence="10"/>

    <!-- CONFIG -->

    <menuitem
        id="menu_smart_search_config"
        name="Configurations"
        parent="menu_smart_search_root"
        sequence="20"/>

    <!-- EZ BASE -->

    <menuitem
        id="menu_smart_search_ezbase_config"
        name="EZ Base Configuration"
        parent="menu_smart_search_config"
        action="action_smart_search_config"
        sequence="10"/>

    <!-- RESULTS -->

    <menuitem
        id="menu_smart_search_results"
        name="Search Results"
        parent="menu_smart_search_root"
        action="action_smart_search_results"
        sequence="30"/>

</odoo>