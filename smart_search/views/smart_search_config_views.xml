<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- TREE VIEW -->

    <record id="view_smart_search_config_tree"
            model="ir.ui.view">

        <field name="name">smart.search.config.tree</field>
        <field name="model">smart.search.config</field>

        <field name="arch" type="xml">

            <list>
                <field name="name"/>
                <field name="ez_base_url"/>
                <field name="ez_username"/>
            </list>

        </field>
    </record>

    <!-- FORM VIEW -->

    <record id="view_smart_search_config_form"
            model="ir.ui.view">

        <field name="name">smart.search.config.form</field>
        <field name="model">smart.search.config</field>

        <field name="arch" type="xml">

            <form>
                <sheet>

                    <group>
                        <field name="name"/>
                        <field name="active"/>
                    </group>

                    <group>
                        <field name="ez_base_url"/>
                        <field name="ez_category1_id"/>
                        <field name="ez_category2_id"/>
                    </group>

                    <group string="EZ-Base Credentials (Optional)">
                        <field name="ez_username"/>
                        <field name="ez_password" password="True"/>
                    </group>

                    <group>
                        <field name="search_field_id"/>
                    </group>

                </sheet>
            </form>

        </field>
    </record>

    <!-- ACTION -->

    <record id="action_smart_search_config"
            model="ir.actions.act_window">

        <field name="name">EZ Base Configuration</field>

        <field name="res_model">smart.search.config</field>

        <field name="view_mode">list,form</field>

    </record>

</odoo>