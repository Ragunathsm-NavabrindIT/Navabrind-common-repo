<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- PRODUCT TEMPLATE FORM INHERIT -->

    <record id="view_product_template_form_smart_search"
            model="ir.ui.view">

        <field name="name">product.template.form.smart.search</field>

        <field name="model">product.template</field>

        <field name="inherit_id"
               ref="product.product_template_only_form_view"/>

        <field name="arch"
               type="xml">

            <!-- ADD BUTTON INSIDE HEADER -->

            <xpath expr="//header"
                   position="inside">

                <button name="action_fetch_product_details"
                        type="object"
                        string="Smart Search"
                        class="btn-primary"/>

            </xpath>

        </field>

    </record>

</odoo>